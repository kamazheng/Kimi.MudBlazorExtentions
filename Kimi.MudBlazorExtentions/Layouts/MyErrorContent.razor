@using Kimi.MudBlazorExtentions.Components
@using System.Text.Json
<MudContainer Class="pa-3">
    <MudStack Spacing="2" Class="ml-5 mt-3">
        <MudText Typo="Typo.h5" Color="Color.Error">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Class="mr-2 mb-n1" />出错了
        </MudText>
        @if (CurrentException is not null)
        {
            @* 默认：只显示主要报错信息 *@
            <MudAlert Severity="Severity.Error" Style="word-wrap:break-word;word-break:break-word;">@PrimaryMessage</MudAlert>

            @* 详情：完整调试信息（服务器 InnerException 链 + 客户端堆栈） *@
            @if (readmore)
            {
                @if (!string.IsNullOrWhiteSpace(ServerException))
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-2">服务器异常详情（含 InnerException）</MudText>
                    <MudPaper Outlined="true" Class="pa-2" Style="max-height:40vh;overflow:auto;">
                        <pre style="white-space:pre-wrap;word-break:break-word;margin:0;font-family:monospace;">@ServerException</pre>
                    </MudPaper>
                }
                else if (!string.IsNullOrWhiteSpace(RawBody))
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-2">响应内容</MudText>
                    <JsonViewer JsonData="@RawBody" />
                }

                <MudText Typo="Typo.subtitle2" Class="mt-2">客户端异常（含堆栈/InnerException）</MudText>
                <MudPaper Outlined="true" Class="pa-2" Style="max-height:40vh;overflow:auto;">
                    <pre style="white-space:pre-wrap;word-break:break-word;margin:0;font-family:monospace;">@CurrentException.ToString()</pre>
                </MudPaper>
            }
        }
        <MudItem>
            @if (IfDialog != true)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Class="mr-3" OnClick="ClearError">Clear Error</MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ToggleReadMore">@(readmore ? "收起详情" : "详情")</MudButton>
        </MudItem>
    </MudStack>
</MudContainer>

@code {
    [Parameter]
    public Exception? CurrentException { get; set; }

    [Parameter]
    public ErrorBoundaryBase? errorBoundary { get; set; }

    [Parameter]
    public bool? IfDialog { get; set; } = false;

    [Inject]
    public NavigationManager? _navigation { get; set; }

    public bool readmore { get; set; } = false;

    // 主要报错信息（EnsureSuccessCode 已把 ex.Message 友好化）
    private string PrimaryMessage { get; set; } = "";
    // 服务器 InnerException 链（来自 ex.Data["serverException"]）
    private string? ServerException { get; set; }
    // 原始响应体（来自 ex.Data["body"]），用于 JsonViewer 结构化展示
    private string? RawBody { get; set; }

    protected override void OnParametersSet()
    {
        ServerException = null;
        RawBody = null;
        PrimaryMessage = "发生未知错误";

        if (CurrentException is null)
        {
            return;
        }

        var message = CurrentException.Message;
        PrimaryMessage = string.IsNullOrWhiteSpace(message)
            ? $"请求失败（{CurrentException.GetType().Name}）"
            : message;

        // 结构化数据优先从 ex.Data 读（由 EnsureSuccessCode 填充）
        if (CurrentException.Data["serverException"] is string se && !string.IsNullOrWhiteSpace(se))
        {
            ServerException = se;
        }
        if (CurrentException.Data["body"] is string body && !string.IsNullOrWhiteSpace(body))
        {
            RawBody = body;
        }

        // 退化：无 Data 时尝试把 Message 当 ProblemDetails JSON 解析（兼容其它抛出点）
        if (ServerException is null && RawBody is null && !string.IsNullOrWhiteSpace(message))
        {
            try
            {
                using var doc = JsonDocument.Parse(message);
                if (doc.RootElement.ValueKind == JsonValueKind.Object)
                {
                    var root = doc.RootElement;
                    PrimaryMessage = GetString(root, "detail")
                        ?? GetString(root, "message")
                        ?? GetString(root, "title")
                        ?? PrimaryMessage;
                    ServerException = GetString(root, "exception");
                    RawBody = message;
                }
            }
            catch
            {
                // 非 JSON：维持原 Message 作为主消息
            }
        }
    }

    private static string? GetString(JsonElement obj, string name)
        => obj.TryGetProperty(name, out var v) && v.ValueKind == JsonValueKind.String ? v.GetString() : null;

    private void ToggleReadMore() => readmore = !readmore;

    private void ClearError(MouseEventArgs e)
    {
        errorBoundary?.Recover();
        if (_navigation is not null)
        {
            _navigation.Refresh(forceReload: true);
        }
    }
}
