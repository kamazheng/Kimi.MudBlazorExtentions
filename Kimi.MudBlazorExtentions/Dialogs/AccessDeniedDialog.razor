<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Rounded.Lock" Color="Color.Error" Class="mr-2 mb-n1" />
            权限不足
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Error" Class="mb-3" Style="word-break:break-word;">@Message</MudAlert>

        @if (MissingRoles is { Count: > 0 })
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2">需要以下角色</MudText>
            <div class="d-flex flex-wrap gap-2 mt-1">
                @foreach (var role in MissingRoles)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">@role</MudChip>
                }
            </div>
        }

        @if (MissingPermissions is { Count: > 0 })
        {
            <MudText Typo="Typo.subtitle2" Class="mt-3">需要以下权限</MudText>
            <div class="d-flex flex-wrap gap-2 mt-1">
                @foreach (var perm in MissingPermissions)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">@perm</MudChip>
                }
            </div>
        }

        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">如需开通访问权限，请联系系统管理员。</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">知道了</MudButton>
    </DialogActions>
</MudDialog>
